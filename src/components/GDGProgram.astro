---
import { Image } from "astro:assets";
import gdgImage from "../assets/images/gdg-image1.png";
import MapPin from "../assets/images/mapPin-icon.svg";
import PersonIcon from "../assets/images/person-icon.svg";
import CalendarIcon from "../assets/images/calendar-icon.svg";
import ExternalLinkIcon from "../assets/images/external-link-icon.svg";
import { teamMembers } from "../data/teamMembers";
import { coreTeamMembers } from "../data/teamMembers.ts";
---

<div
  class="flex flex-shrink-0 flex-grow-0 flex-col items-center justify-center self-stretch px-5 py-[50px]"
  id="comunidades"
>
  <div class="internal-container">
    <div class="container-left">
      <div
        class="flex w-fit justify-center gap-2 rounded-[14px] bg-[#1DE9B633] p-2 px-4"
      >
        <Image src={PersonIcon} alt="person icon" />
        <span class="text-[14px] font-semibold text-[#101828]">
          comunidad destacada
        </span>
      </div>
      <span class="text-title">GDG Cochabamba</span>
      <p class="text-description">
        Google Developer Group Cochabamba es una comunidad de desarrolladores
        apasionados por las tecnologías de Google. Organizamos eventos, talleres
        y charlas para compartir conocimiento y fomentar la innovación
        tecnológica en Bolivia.
      </p>
      <div class="gdg-stats-grid">
        <article class="gdg-stat-card">
          <Image src={PersonIcon} alt="person icon" />
          <span class="gdg-stat-value">100+</span>
          <span class="gdg-stat-label">Miembros</span>
        </article>
        <article class="gdg-stat-card">
          <Image src={CalendarIcon} alt="calendar icon" />
          <span class="gdg-stat-value">50+</span>
          <span class="gdg-stat-label">Eventos</span>
        </article>
      </div>
      <div class="flex items-start gap-2">
        <Image src={MapPin} alt="mapPin" />
        <span> Cochabamba - Bolivia</span>
      </div>
      <a
        class="btn-gdg"
        href="https://www.instagram.com/gdgcochabamba/"
        target="_blank"
        rel="noopener noreferrer"
      >
        <p class="text-[#101828]">Conocer GDG Cochabamba</p>
        <Image src={ExternalLinkIcon} alt="external link icon" />
      </a>
    </div>

    <div class="container-right">
      <Image src={gdgImage} alt="gdgImage" class="image-gdg" />
      <div class="container-team">
        <span class="team-title">Equipo Core</span>
        <div class="team-grid">
          {coreTeamMembers.slice(0, 4).map((member) => (
            <div class="team-member">
              <img
                src={member.photo}
                alt={member.name}
                class="member-photo"
                loading="lazy"
              />
              <span class="member-name">{member.name}</span>
            </div>
          ))}
        </div>
        <div class="team-grid team-grid-extra" id="extra-members">
          {coreTeamMembers.slice(4).map((member) => (
            <div class="team-member">
              <img
                src={member.photo}
                alt={member.name}
                class="member-photo"
                loading="lazy"
              />
              <span class="member-name">{member.name}</span>
            </div>
          ))}
        </div>
        <button class="btn-ver-mas" id="btn-ver-mas" aria-expanded="false">
          Ver más
        </button>
      </div>
    </div>
  </div>
</div>

<style>
  .internal-container {
    width: 70%;
    max-width: 1200px;
    display: flex;
    flex-direction: row;
    justify-content: center;
    align-items: center;
    border-radius: 10px;
    background-color: white;
    box-shadow: 0px 25px 50px -12px rgba(0, 0, 0, 0.25);
  }
  .internal-container > * {
    width: 100%;
    max-width: 100%;
    align-self: stretch;
  }
  .container-left {
    display: flex;
    flex: 1;
    flex-direction: column;
    justify-content: center;
    gap: 1rem;
    padding: 48px;
  }
  .container-right {
    display: flex;
    flex: 1;
    flex-direction: column;
    justify-content: center;
    padding: 48px;
    gap: 0.5rem;
    align-items: center;
    background-color: #f9fafb;
    border-radius: 0 10px 10px 0;
  }
  .text-title {
    font-size: 36px;
    color: #101828;
    font-weight: 900;
  }
  .text-description {
    text-size: 16px;
    color: #4a5565;
    font-weight: 400;
    line-height: 26px;
  }
  .gdg-info,
  .gdg-side {
    width: 100%;
  }
  .gdg-stats-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
    width: 100%;
  }
  .gdg-stat-card {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: center;
    gap: 0.2rem;
    padding: 0.5rem 1.25rem;
    border-radius: 14px;
    background-color: #f9fafb;
  }
  .gdg-stat-value {
    font-size: 1.5rem;
    font-weight: 800;
    color: #101828;
  }
  .gdg-stat-label {
    font-size: 0.875rem;
    font-weight: 400;
    color: #4a5565;
  }
  .image-gdg {
    width: 100%;
    height: auto;
    border-radius: 16px;
  }
  .text-info-gdg {
    flex-shrink: 0;
    flex-grow: 0;
    align-self: stretch;
    width: 100%;
  }

  .btn-gdg {
    display: flex;
    width: fit-content;
    align-items: center;
    justify-content: center;
    gap: 8px;
    background-color: #1de9b6;
    border-radius: 14px;
    border: none;
    cursor: pointer;
    padding: 12px 40px;
    box-shadow:
      0px 2px 4px -2px rgba(0, 0, 0, 0.1),
      0px 4px 6px -1px rgba(0, 0, 0, 0.1);
    transition:
      transform 0.2s ease,
      background-color 0.2s ease;
  }
  .btn-gdg p {
    color: #101828;
    margin: 0;
    font-weight: 500;
  }
  .btn-gdg:hover {
    background-color: #17d3a5;
    transform: translateY(-2px);
  }

  .container-team {
    displey: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding-top: 15px;
  }
  .team-title {
    font-weight: 700;
  }
  .team-grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: 16px 35px;
    padding-top: 16px;
    width: 100%;
  }
  .team-member {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 4px;
    width: 100px;
  }

  .member-photo {
    height: 80px;
    width: 80px;
    border-radius: 14px;
    object-fit: cover;
  }

  .member-name {
    font-size: 14px;
    font-weight: 600;
    text-align: center;
    color: #4a5565;
  }

  @media (max-width: 1024px) {
    .internal-container {
      width: 90%;
      max-width: 90%;
      gap: 1rem;
      flex-direction: column;
    }
    .container-left {
      align-items: center;
    }
    .container-right {
      border-radius: 0 0 10px 10px;
    }
    .text-description {
      text-align: center;
    }
  }

  @media (max-width: 640px) {
    .internal-container {
      flex-direction: column;
      width: 100%;
      gap: 1.5rem;
    }
    .internal-container > * {
      width: 100%;
      align-self: stretch;
    }
    .container-left {
      width: 100%;
      padding: 24px;
    }
    .container-right {
      border-radius: 0 10px 10px 0;
      padding: 24px;
    }
    .text-title {
      font-size: 28px;
    }
    .text-description {
      text-size: 14px;
    }
    .btn-gdg {
      padding: 12px 25px;
    }

    .container-team {
      display: none;
    }
  }
  @media (max-width: 460px) {
    .btn-gdg {
      padding: 12px 15px;
    }
  }

  .team-grid-extra {
    display: none;
  }
  .team-grid-extra.visible {
    display: flex;
  }

  .btn-ver-mas {
    display: block;
    margin: 12px auto 0;
    background: none;
    border: 1.5px solid #1de9b6;
    color: #101828;
    border-radius: 14px;
    padding: 8px 28px;
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    transition:
      background-color 0.2s ease,
      transform 0.2s ease;
  }
  .btn-ver-mas:hover {
    background-color: #1de9b633;
    transform: translateY(-1px);
  }
</style>

<script>
  const btn = document.getElementById("btn-ver-mas");
  const extra = document.getElementById("extra-members");

  btn?.addEventListener("click", () => {
    const expanded = btn.getAttribute("aria-expanded") === "true";
    extra?.classList.toggle("visible", !expanded);
    btn.setAttribute("aria-expanded", String(!expanded));
    btn.textContent = expanded ? "Ver más" : "Ver menos";
  });
</script>
