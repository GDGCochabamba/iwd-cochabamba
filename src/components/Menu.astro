---
import { Image } from "astro:assets";
import logoWtm from "../assets/images/WiñayTech.svg";

---

<nav class="fixed left-0 top-0 w-full py-4 bg-white shadow-md z-50">
  <div class="flex justify-between items-center px-2 md:px-8">
    <a href="/" class="flex items-center flex-shrink-0">
      <Image
        class="w-[80px] md:w-[140px]"
        src={logoWtm}
        alt="Logo WTM Cochabamba"
      />
    </a>

    <div class="hidden md:flex items-center space-x-8 flex-1 justify-end">
      <a href="/" class="text-gray-700 hover:text-pink-600 font-medium transition">
        Inicio
      </a>
      <a href="#speakers" class="text-gray-700 hover:text-pink-600 font-medium transition">
        Charlas
      </a>
      <a href="#about-winaytech" class="text-gray-700 hover:text-pink-600 font-medium transition">
       Sobre WiñayTech
      </a>
      <a href="#comunidades" class="text-gray-700 hover:text-pink-600 font-medium transition">
        Comunidades
      </a>
      <a href="#equipo" class="text-gray-700 hover:text-pink-600 font-medium transition">
        Equipo
      </a>
       <a href="#aliados" class="text-gray-700 hover:text-pink-600 font-medium transition">
        Aliados
      </a>
       <a href="#footer" class="text-gray-700 hover:text-pink-600 font-medium transition">
        FAQ
      </a>
      <a href="https://events.gdg.com.bo/winay-tech-26 " class="text-gray-700 px-6 py-2 rounded-lg transition font-bold" style="background-color: rgba(29, 233, 182, 1);">
        Inscribirme
      </a>
    </div>

    <div class="md:hidden">
      <a href="https://events.gdg.com.bo/winay-tech-26 " class="text-gray-700 px-4 py-2 rounded-lg transition font-bold text-sm" style="background-color: rgba(29, 233, 182, 1);">
        Inscribirme
      </a>
    </div>
  </div>
</nav>

