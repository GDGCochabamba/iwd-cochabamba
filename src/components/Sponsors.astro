---
import { allTiers } from "../data/sponsors";
import SponsorCard from "./SponsorCard.astro";

const activeTiers = allTiers.filter((tier) =>
  tier.sponsors.some((arr) => arr.length > 0),
);
---

<section id="aliados" class="px-6 py-16 md:px-10 md:py-20">
  <h2 class="text-center text-3xl font-bold text-gray-900 md:text-4xl">
    Nuestros Aliados
  </h2>
  <p class="mt-3 text-center text-base text-gray-600 md:text-lg">
    Gracias a estas organizaciones que apoyan el crecimiento del ecosistema tech
    boliviano
  </p>
  <div class="mx-auto mt-12 max-w-5xl space-y-14">
    {
      activeTiers.map((tier) => (
        <div>
          <h3 class={`text-center text-xl font-bold ${tier.color} md:text-2xl`}>
            {tier.name}
          </h3>
          <div class={`mx-auto mt-2 h-1 w-16 rounded ${tier.accentColor}`} />

          <div class="mt-8 flex flex-wrap items-center justify-center gap-4 md:gap-6">
            {/* Array 1 - Siempre visible */}
            {tier.sponsors[0].map((sponsor) => (
              <SponsorCard
                sponsor={sponsor}
                bgColor={tier.bgColor}
                iconColor={tier.iconColor}
                icon={tier.icon}
                textColor={tier.textColor}
              />
            ))}

            {/* Array 2 - Visible en tablet+ */}
            <div class="hidden md:contents">
              {tier.sponsors[1].map((sponsor) => (
                <SponsorCard
                  sponsor={sponsor}
                  bgColor={tier.bgColor}
                  iconColor={tier.iconColor}
                  icon={tier.icon}
                  textColor={tier.textColor}
                />
              ))}
            </div>

            {/* Array 3 - Solo desktop */}
            <div class="hidden lg:contents">
              {tier.sponsors[2].map((sponsor) => (
                <SponsorCard
                  sponsor={sponsor}
                  bgColor={tier.bgColor}
                  iconColor={tier.iconColor}
                  icon={tier.icon}
                  textColor={tier.textColor}
                />
              ))}
            </div>
          </div>
        </div>
      ))
    }
  </div>
</section>
