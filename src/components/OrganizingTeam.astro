---
import { teamMembers } from "../data/teamMembers";
import logoInstagram from "../assets/images/logo-instagram.svg";
import logoFacebook from "../assets/images/logo-facebook.svg";
import logoLinkedin from "../assets/images/logo-linkedin.svg";
import { Image } from "astro:assets";
---

<div
  class="flex flex-col justify-start items-center self-stretch flex-grow-0 flex-shrink-0 gap-2.5 px-6 py-20 bg-white"
>
  <div class="flex flex-col justify-start items-center flex-grow-0 flex-shrink-0 w-[1024px] gap-12">
    <div
      class="flex flex-col justify-start items-center self-stretch flex-grow-0 flex-shrink-0 relative"
    >
      <p
        class="self-stretch flex-grow-0 flex-shrink-0 w-[1024px] text-[40px] text-center text-[#202124]"
      >
        Equipo Organizador
      </p>
    </div>

    <div class="members-grid">
      {teamMembers.map((member) => (
        <div class="member-card">
          <img
            src={member.photo}
            alt={member.name}
            class="card-photo"
            loading="lazy"
          />
          <div class="card-info">
            <p class="card-name">{member.name}</p>
          </div>
          <div class="card-footer">
            {member.instagram && (
              <a href={member.instagram} target="_blank" rel="noopener" class="social-link">
                <Image src={logoInstagram} alt="Instagram" width={18} height={18} />
              </a>
            )}
            {member.facebook && (
              <a href={member.facebook} target="_blank" rel="noopener" class="social-link">
                <Image src={logoFacebook} alt="Facebook" width={18} height={18} />
              </a>
            )}
            {member.linkedin && (
              <a href={member.linkedin} target="_blank" rel="noopener" class="social-link">
                <Image src={logoLinkedin} alt="LinkedIn" width={18} height={18} />
              </a>
            )}
          </div>
        </div>
      ))}
    </div>
  </div>
</div>

<style>
  .members-grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 24px;
    width: 100%;
  }

  .member-card {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    align-items: center;
    width: 180px;
    border-radius: 12px;
    background: white;
    border: 1px solid #dadce0;
    overflow: hidden;
    padding-top: 20px;
  }

  .card-photo {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    object-fit: cover;
  }

  .card-info {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 8px 12px 0;
    flex: 1;
  }

  .card-name {
    font-size: 14px;
    font-weight: 700;
    text-align: center;
    color: #202124;
    margin: 0;
  }

  .card-footer {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 10px;
    width: 100%;
    padding: 12px 16px;
    margin-top: 8px;
    background-color: #f9f9f9;
    border-top: 1px solid #dadce0;
    min-height: 48px;
  }

  .social-link {
    display: flex;
    align-items: center;
    opacity: 0.75;
    transition: opacity 0.2s ease;
  }

  .social-link:hover {
    opacity: 1;
  }

  @media (max-width: 1100px) {
    .flex-grow-0.flex-shrink-0.w-\[1024px\] {
      width: 100%;
    }
  }

  @media (max-width: 640px) {
    .member-card {
      width: 150px;
    }
  }
</style>
