---
import { teamMembers } from "../data/teamMembers";
import logoInstagram from "../assets/images/logo-instagram.svg";
import logoFacebook from "../assets/images/logo-facebook.svg";
import logoLinkedin from "../assets/images/logo-linkedin.svg";
import { Image } from "astro:assets";

const filterCategories = [
  "Todos",
  "Sponsors",
  "Decoración",
  "Speakers",
  "Video",
  "Marketing",
  "Diseño",
  "Logística",
  "Dinámicas",
  "Web",
  "Registro",
  "Staff",
];
---

<div
  class="flex flex-col justify-start items-center self-stretch flex-grow-0 flex-shrink-0 gap-2.5 px-6 py-20 bg-white"
>
  <div class="inner-wrapper">
    <p class="section-title">Equipo Organizador</p>

    <!-- Search -->
    <div class="search-wrap">
      <svg class="search-icon" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
        <circle cx="9" cy="9" r="6" stroke="#9CA3AF" stroke-width="1.8"/>
        <path d="M13.5 13.5L17 17" stroke="#9CA3AF" stroke-width="1.8" stroke-linecap="round"/>
      </svg>
      <input
        id="team-search"
        type="text"
        placeholder="Buscar por nombre o rol..."
        class="search-input"
        autocomplete="off"
      />
    </div>

    <!-- Filter chips -->
    <div class="chips-row">
      {filterCategories.map((cat) => (
        <button
          class={`chip${cat === "Todos" ? " chip-active" : ""}`}
          data-filter={cat}
        >
          {cat}
        </button>
      ))}
    </div>

    <!-- Cards -->
    <div class="members-grid" id="members-grid">
      {teamMembers.map((member) => {
        const roleLabels = (member.roles ?? []).map((r) => r.label).join(",");
        return (
          <div
            class="member-card"
            data-name={member.name.toLowerCase()}
            data-roles={roleLabels.toLowerCase()}
          >
            <img
              src={member.photo}
              alt={member.name}
              class="card-photo"
              loading="lazy"
            />
            <div class="card-info">
              <p class="card-name">{member.name}</p>
              {member.roles && member.roles.length > 0 && (
                <div class="role-badges">
                  {member.roles.map((role) => (
                    <span class="role-badge" style={`--dot: ${role.color}`}>
                      <span class="role-dot" />
                      {role.label}
                    </span>
                  ))}
                </div>
              )}
            </div>
            <div class="card-footer">
              {member.instagram && (
                <a href={member.instagram} target="_blank" rel="noopener" class="social-link">
                  <Image src={logoInstagram} alt="Instagram" width={18} height={18} />
                </a>
              )}
              {member.facebook && (
                <a href={member.facebook} target="_blank" rel="noopener" class="social-link">
                  <Image src={logoFacebook} alt="Facebook" width={18} height={18} />
                </a>
              )}
              {member.linkedin && (
                <a href={member.linkedin} target="_blank" rel="noopener" class="social-link">
                  <Image src={logoLinkedin} alt="LinkedIn" width={18} height={18} />
                </a>
              )}
            </div>
          </div>
        );
      })}
    </div>

    <p class="no-results hidden" id="no-results">No se encontraron resultados.</p>
  </div>
</div>

<style>
  .inner-wrapper {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
    max-width: 1100px;
    gap: 24px;
  }

  .section-title {
    font-size: 40px;
    font-weight: 800;
    text-align: center;
    color: #202124;
    margin: 0;
  }

  /* Search */
  .search-wrap {
    position: relative;
    width: 100%;
    max-width: 460px;
  }

  .search-icon {
    position: absolute;
    left: 14px;
    top: 50%;
    transform: translateY(-50%);
    width: 18px;
    height: 18px;
    pointer-events: none;
  }

  .search-input {
    width: 100%;
    padding: 10px 16px 10px 42px;
    border: 1.5px solid #e5e7eb;
    border-radius: 999px;
    font-size: 14px;
    color: #374151;
    outline: none;
    transition: border-color 0.2s;
    background: #fff;
    box-sizing: border-box;
  }

  .search-input:focus {
    border-color: #1de9b6;
  }

  /* Chips */
  .chips-row {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 8px;
  }

  .chip {
    padding: 6px 18px;
    border-radius: 999px;
    border: 1.5px solid #e5e7eb;
    background: #fff;
    font-size: 14px;
    font-weight: 500;
    color: #374151;
    cursor: pointer;
    transition: border-color 0.2s, background 0.2s, color 0.2s;
  }

  .chip:hover {
    border-color: #1de9b6;
  }

  .chip-active {
    background: #1de9b6;
    border-color: #1de9b6;
    color: #101828;
    font-weight: 600;
  }

  /* Grid */
  .members-grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 20px;
    width: 100%;
  }

  .member-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 175px;
    border-radius: 12px;
    background: white;
    border: 1px solid #dadce0;
    overflow: hidden;
    padding-top: 20px;
    transition: box-shadow 0.2s;
  }

  .member-card:hover {
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.08);
  }

  .member-card.hidden {
    display: none;
  }

  .card-photo {
    width: 72px;
    height: 72px;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
  }

  .card-info {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 8px 10px 4px;
    flex: 1;
    gap: 6px;
    width: 100%;
  }

  .card-name {
    font-size: 13px;
    font-weight: 700;
    text-align: center;
    color: #202124;
    margin: 0;
  }

  .role-badges {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    width: 100%;
  }

  .role-badge {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-size: 11px;
    color: #4c555b;
    white-space: nowrap;
  }

  .role-dot {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background-color: var(--dot);
    flex-shrink: 0;
  }

  .card-footer {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 10px;
    width: 100%;
    padding: 10px 16px;
    margin-top: auto;
    background-color: #f9f9f9;
    border-top: 1px solid #dadce0;
    min-height: 44px;
  }

  .social-link {
    display: flex;
    align-items: center;
    opacity: 0.7;
    transition: opacity 0.2s;
  }

  .social-link:hover {
    opacity: 1;
  }

  .no-results {
    font-size: 15px;
    color: #6b7280;
    margin: 0;
  }

  .hidden {
    display: none;
  }

  @media (max-width: 640px) {
    .section-title {
      font-size: 28px;
    }
    .member-card {
      width: 148px;
    }
  }
</style>

<script>
  const searchInput = document.getElementById("team-search") as HTMLInputElement;
  const chips = document.querySelectorAll<HTMLButtonElement>(".chip");
  const cards = document.querySelectorAll<HTMLElement>(".member-card");
  const noResults = document.getElementById("no-results")!;

  let activeFilter = "todos";

  function applyFilters() {
    const query = searchInput.value.toLowerCase().trim();
    let visible = 0;

    cards.forEach((card) => {
      const name = card.dataset.name ?? "";
      const roles = card.dataset.roles ?? "";

      const matchesSearch = !query || name.includes(query) || roles.includes(query);
      const matchesFilter =
        activeFilter === "todos" || roles.includes(activeFilter);

      if (matchesSearch && matchesFilter) {
        card.classList.remove("hidden");
        visible++;
      } else {
        card.classList.add("hidden");
      }
    });

    noResults.classList.toggle("hidden", visible > 0);
  }

  searchInput.addEventListener("input", applyFilters);

  chips.forEach((chip) => {
    chip.addEventListener("click", () => {
      chips.forEach((c) => c.classList.remove("chip-active"));
      chip.classList.add("chip-active");
      activeFilter = (chip.dataset.filter ?? "Todos").toLowerCase();
      applyFilters();
    });
  });
</script>
